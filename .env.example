# ═══════════════════════════════════════════════════════════
# APEX BOT v5 ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ── ALPACA TRADING API ────────────────────────────────────
# Get these from https://alpaca.markets
ALPACA_KEY_ID=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Set to "true" for paper trading (recommended for testing)
# Leave blank or "false" for live trading
ALPACA_PAPER=true

# ── GITHUB INTEGRATION (Marshall Bridge) ──────────────────
# Optional: For Savant directive integration
# Generate token at https://github.com/settings/tokens
# Required scopes: read:gists
GITHUB_TOKEN=github_token_here_optional
GITHUB_GIST_ID=gist_id_for_savant_directives_optional

# ── EMAIL NOTIFICATIONS ────────────────────────────────────
# Resend API for alerts (free: 3000/month)
# Get key at https://resend.com
RESEND_KEY=your_resend_api_key_here

# Alternative: Gmail (deprecated, not recommended)
GMAIL_USER=your_gmail_here_optional
GMAIL_PASS=your_gmail_app_password_optional

# ── SERVER CONFIGURATION ───────────────────────────────────
# Port for the dashboard server
PORT=3000

# Environment: production or development
NODE_ENV=development
